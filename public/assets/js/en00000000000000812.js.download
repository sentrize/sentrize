if(iframe_b){let iframe_b_SRC=eraseQueryString(iframe_b.src);iframe_b.src=iframe_b_SRC+'?'+'lead_channel='+medium+'&vid='+vid+'&ga_source='+source+'&ga_medium='+leadChannel['2']+'&ga_term='+term+'&ga_content='+content+'&ga_campaign='+campaign;}
if(iframe_c){let iframe_c_SRC=eraseQueryString(iframe_c.src);iframe_c.src=iframe_c_SRC+'?'+'lead_channel='+medium+'&vid='+vid+'&ga_source='+source+'&ga_medium='+leadChannel['2']+'&ga_term='+term+'&ga_content='+content+'&ga_campaign='+campaign;}}}}}}}});$(function(){$("#thirdPartyPartners").on("click",function(e){$("#thirdPartyPartnersBox").addClass("active");e.stopPropagation();});$(document).on("click",function(e){if($(e.target).is("#thirdPartyPartnersBox")===false){$("#thirdPartyPartnersBox").removeClass("active");}});});document.addEventListener('DOMContentLoaded',()=>{const tabContainer=document.querySelector('.tabContainer');tabContainer.addEventListener('click',(e)=>{const clickedItem=e.target.closest('.boxMenuItem');if(!clickedItem)return;const value=clickedItem.dataset.item;const targetClass='item'+value;tabContainer.querySelectorAll('.itemAll').forEach(el=>el.classList.remove('active'));document.querySelectorAll('.tabContentBox .contentItem').forEach(el=>el.classList.remove('active'));tabContainer.querySelector('.'+targetClass)?.classList.add('active');document.querySelector('.tabContentBox .'+targetClass)?.classList.add('active');});});$(document).ready(function(){$(".dropDown").on('mouseenter',function(){$(this).find(".menu-dropdown").finish().show();}).on("mouseleave",function(){$(this).find(".menu-dropdown").finish().hide();});$('#mobilePrimaryMenu .hamburgerButton').on('click',function(e){e.preventDefault();$(this).toggleClass('active');$('.mobileSecondaryMenu').toggleClass('active');$('.tabletChannelSearch').removeClass('active');$('header').toggleClass('mobileMenuActive');});$('.tabletMenuSearchButtonContainer').on('click',function(e){e.preventDefault();$('.tabletChannelSearch').toggleClass('active');$('.mobileSecondaryMenu, .hamburgerButton').removeClass('active');});$('.desktopSearch').on('click',function(e){e.preventDefault();$('.desktopChannelSearch').toggleClass('active');});$('#mobilePrimaryMenu .dropDown > a').on("click",function(e){var $this=